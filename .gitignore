# =============================================================================
# .gitignore — UE5.5 AI Companion Character Project
# =============================================================================

# -----------------------------------------------------------------------------
# Unreal Engine — Generated / Intermediate / Cache
# -----------------------------------------------------------------------------
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/

# Plugin build artifacts
Plugins/*/Binaries/
Plugins/*/Intermediate/

# Pak files (keep blacklists, ignore everything else)
!Build/*/PakBlacklist*.txt
Build/*/
Build/**/*

# Precompiled art assets
SourceArt/**/*.png
SourceArt/**/*.tga

# -----------------------------------------------------------------------------
# Visual Studio / VS Code
# -----------------------------------------------------------------------------
.vs/
.vscode/
*.sln
*.suo
*.vcxproj*
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.user
*.userprefs

# -----------------------------------------------------------------------------
# Xcode
# -----------------------------------------------------------------------------
*.xcodeproj
*.xcworkspace

# -----------------------------------------------------------------------------
# Compiled Objects & Precompiled Headers
# -----------------------------------------------------------------------------
*.o
*.obj
*.lo
*.slo
*.gch
*.pch

# -----------------------------------------------------------------------------
# Libraries (Static & Dynamic)
# -----------------------------------------------------------------------------
*.dll
*.dylib
*.so
*.a
*.lib

# -----------------------------------------------------------------------------
# Executables
# -----------------------------------------------------------------------------
*.exe
*.out
*.app
*.ipa

# -----------------------------------------------------------------------------
# OS-Specific Junk
# -----------------------------------------------------------------------------
# macOS
.DS_Store
._*

# Windows
Thumbs.db
Desktop.ini

# Linux
*~

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
# Crashpad / crash report dumps
*.dmp
CrashReportClient/

# Local editor preferences (not needed in repo)
*.code-workspace